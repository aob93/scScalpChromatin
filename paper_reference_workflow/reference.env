#!/usr/bin/env bash

# Reference workflow environment for the Brown Lab Biowulf checkout.

# Project checkout location.
export SCSCALP_PROJECT_ROOT="/vf/users/Brown_lab/Aidan/scMultiome/GSE212450/scScalpChromatin"

# Root for generated outputs.
export SCSCALP_RESULTS_ROOT="/vf/users/Brown_lab/Aidan/scMultiome/GSE212450/scScalpChromatin/results"

# ATAC fragment input root.
export SCSCALP_RAW_ATAC_FRAGMENT_DIR="/data/Brown_lab/Aidan/scMultiome/GSE212450/processed_files/ATAC_fragments/"

# Optional demuxlet input used by pooled C_SD ATAC data.
# export SCSCALP_DEMUXLET_BEST="/path/to/C_SD_POOL.best"

# Full RNA reference Seurat object used by 04_full_RNA_integration.R
export SCSCALP_RNA_REFERENCE_RDS="/data/Brown_lab/Aidan/scMultiome/GSE212450/processed_files/RNA_seurat/seurat_objects/scalp.rds"

# RNA subgroup Seurat references used by the 02b / 03b / 04b / 04c ATAC scripts.
# Expected layouts:
#   /path/to/rna_subclusters/Keratinocytes/Keratinocytes.rds
#   /path/to/rna_subclusters/Keratinocytes.rds
export SCSCALP_RNA_REFERENCE_SUBCLUSTER_DIR="/data/Brown_lab/Aidan/scMultiome/GSE212450/processed_files/RNA_seurat/seurat_objects/"

# Optional subgroup-specific overrides.
# export SCSCALP_RNA_REFERENCE_SUBGROUP_ENDOTHELIAL_RDS="/path/to/Endothelial.rds"
# export SCSCALP_RNA_REFERENCE_SUBGROUP_FIBROBLASTS_RDS="/path/to/Fibroblasts.rds"
# export SCSCALP_RNA_REFERENCE_SUBGROUP_KERATINOCYTES_RDS="/path/to/Keratinocytes.rds"
# export SCSCALP_RNA_REFERENCE_SUBGROUP_LYMPHOID_RDS="/path/to/Lymphoid.rds"
# export SCSCALP_RNA_REFERENCE_SUBGROUP_MYELOID_RDS="/path/to/Myeloid.rds"

# Optional Rscript override.
# export R_BIN="Rscript"

# Optional package checks.
# export SCSCALP_PKG_ARCHR="==1.0.1"
# export SCSCALP_PKG_SEURAT=">=5.0.0"
# export SCSCALP_PKG_HARMONY=">=1.0.0"
# export SCSCALP_PKG_MCLUST=">=5.4.7"

# Optional future globals size override for Seurat-heavy helper code.
# export SCSCALP_FUTURE_GLOBALS_MAXSIZE="20G"

# Optional: force clustering to use the kNN graph instead of the SNN graph
# when Seurat graph construction is too memory intensive.
# export SCSCALP_CLUSTER_USE_KNN_ONLY="1"
