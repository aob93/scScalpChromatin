#!/usr/bin/env bash

# Copy this file to biowulf/scscalp.env and edit the values for your account.

# Absolute path to the cloned repo on Biowulf.
export SCSCALP_PROJECT_ROOT="$HOME/scScalpChromatin"

# Where pipeline outputs should be written.
export SCSCALP_RESULTS_ROOT="/data/$USER/scScalpChromatin/results"

# Input data locations.
export SCSCALP_RAW_RNA_DIR="/data/$USER/scScalpChromatin/input/scRNA/filtered_feature_bc_matrices"
export SCSCALP_RAW_ATAC_FRAGMENT_DIR="/data/$USER/scScalpChromatin/input/scATAC/fragment_files"

# Optional demuxlet input. Leave commented out if not needed.
# export SCSCALP_DEMUXLET_BEST="/data/$USER/scScalpChromatin/input/demuxlet/C_SD_POOL.best"

# Optional: point at a specific Rscript binary if you do not want the module default.
# export R_BIN="Rscript"

# Optional package version checks.
# export SCSCALP_PKG_SEURAT=">=5.0.0"
# export SCSCALP_PKG_ARCHR="==1.0.3"
# export SCSCALP_PKG_HARMONY=">=1.2.0"

# Optional: increase if Seurat/future reports exported globals are too large.
# Examples: "20G", "50G", "150G"
# export SCSCALP_FUTURE_GLOBALS_MAXSIZE="20G"

# Optional: force clustering to use the kNN graph instead of Seurat's SNN graph.
# Useful if large merged objects hit std::bad_alloc during FindNeighbors().
# export SCSCALP_CLUSTER_USE_KNN_ONLY="1"
