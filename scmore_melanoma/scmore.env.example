#!/usr/bin/env bash

# Copy to scmore_melanoma/scmore.env and edit for your environment.

# Root of this repo checkout.
export SCMORE_PROJECT_ROOT="$HOME/scScalpChromatin"

# Output directory for the scMORE melanoma workflow.
export SCMORE_RESULTS_ROOT="/data/$USER/scmore_melanoma"

# Trait label used in output filenames.
export SCMORE_TRAIT_NAME="melanoma"

# Raw GWAS summary statistics input.
export SCMORE_RAW_SUMSTATS="/path/to/melanoma_gwas_sumstats.txt.gz"

# Summary-stat column mappings.
# One of P or LP is required. If P is provided, LP is computed as -log10(P).
export SCMORE_SUMSTAT_CHR_COL="CHR"
export SCMORE_SUMSTAT_POS_COL="POS"
export SCMORE_SUMSTAT_A1_COL="A1"
export SCMORE_SUMSTAT_A2_COL="A2"
export SCMORE_SUMSTAT_BETA_COL="BETA"
# export SCMORE_SUMSTAT_OR_COL="OR"
export SCMORE_SUMSTAT_SE_COL="SE"
export SCMORE_SUMSTAT_P_COL="P"
# export SCMORE_SUMSTAT_LP_COL="LP"
export SCMORE_SUMSTAT_AF_COL="AF"
export SCMORE_SUMSTAT_N_COL="N"
export SCMORE_SUMSTAT_SNP_COL="SNP"

# Coordinate build for FUMA upload. Choose the matching option on the FUMA job page.
# Common values are hg19 or hg38.
export SCMORE_SUMSTAT_BUILD="hg38"

# Raw gene-level results from MAGMA or FUMA.
export SCMORE_RAW_GENE_RESULTS="/path/to/melanoma_magma.genes.out"
export SCMORE_GENE_SOURCE="MAGMA"

# Gene-result column mappings.
export SCMORE_GENE_ID_COL="GENE"
export SCMORE_GENE_CHR_COL="CHR"
export SCMORE_GENE_START_COL="START"
export SCMORE_GENE_STOP_COL="STOP"
export SCMORE_GENE_NSNPS_COL="NSNPS"
export SCMORE_GENE_NPARAM_COL="NPARAM"
export SCMORE_GENE_N_COL="N"
export SCMORE_GENE_ZSTAT_COL="ZSTAT"
export SCMORE_GENE_P_COL="P"
# Optional for FUMA-like inputs.
# export SCMORE_GENE_SYMBOL_COL="SYMBOL"

# Final integrated ArchR project directory from the ATAC workflow.
export SCMORE_ARCHR_PROJECT_DIR="/path/to/scATAC_preprocessing/fine_clustered"

# Which disease states to keep when exporting the multimodal object.
# Recommended primary analysis: controls only.
export SCMORE_KEEP_DISEASE_STATUS="C_SD,C_PB"

# Metadata column to use as cell-type label in the exported Seurat object.
export SCMORE_CELLTYPE_COLUMN="NLabelClust_RNA"

# Optional additional cell filter. Leave empty unless needed.
# export SCMORE_KEEP_SAMPLES="C_PB_1,C_PB_2,C_SD_1"

# Output multimodal Seurat object.
export SCMORE_MULTIOME_RDS="\${SCMORE_RESULTS_ROOT}/inputs/\${SCMORE_TRAIT_NAME}_controls_multimodal.rds"

# scMORE runtime parameters.
export SCMORE_N_TARGETS="5"
export SCMORE_PERM_N="1000"
export SCMORE_THETA="0.5"
export SCMORE_ALPHA="1"
export SCMORE_BUFFER="500"
export SCMORE_TOP_N="5"
export SCMORE_P1="0.05"
export SCMORE_P2="0.05"
export SCMORE_P3="0.05"
export SCMORE_PEAK2GENE_METHOD="Signac"
export SCMORE_INFER_METHOD="glm"
export SCMORE_SPECIFICITY_METHOD="cosine"
export SCMORE_SEED="1234"

# Optional explicit Rscript binary.
# export R_BIN="Rscript"
